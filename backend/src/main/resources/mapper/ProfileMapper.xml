<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.personalblog.mapper.ProfileMapper">

    <resultMap id="ProfileMap" type="com.personalblog.entity.ProfileEntity">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="name" property="name"/>
        <result column="subtitle" property="subtitle"/>
        <result column="bio" property="bio"/>
        <result column="focus_json" property="focusJson"/>
        <result column="avatar_url" property="avatarUrl"/>
        <result column="site_owner" property="siteOwner"/>
    </resultMap>

    <sql id="ProfileColumns">
        id, user_id, name, subtitle, bio, focus_json, avatar_url, site_owner
    </sql>

    <select id="selectById" resultMap="ProfileMap">
        SELECT <include refid="ProfileColumns"/> FROM profile WHERE id = #{id}
    </select>

    <select id="selectByUserId" resultMap="ProfileMap">
        SELECT <include refid="ProfileColumns"/> FROM profile WHERE user_id = #{userId}
    </select>

    <select id="selectSiteOwner" resultMap="ProfileMap">
        SELECT <include refid="ProfileColumns"/> FROM profile WHERE site_owner = 1 LIMIT 1
    </select>

    <select id="countSiteOwners" resultType="int">
        SELECT COUNT(*) FROM profile WHERE site_owner = 1
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO profile (user_id, name, subtitle, bio, focus_json, avatar_url, site_owner)
        VALUES (#{userId}, #{name}, #{subtitle}, #{bio}, #{focusJson}, #{avatarUrl}, #{siteOwner})
    </insert>

    <update id="update">
        UPDATE profile
        SET name = #{name},
            subtitle = #{subtitle},
            bio = #{bio},
            focus_json = #{focusJson},
            avatar_url = #{avatarUrl},
            site_owner = #{siteOwner}
        WHERE id = #{id}
    </update>
</mapper>
