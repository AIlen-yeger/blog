<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.personalblog.mapper.TimelineMapper">

    <resultMap id="TimelineMap" type="com.personalblog.entity.TimelineEntity">
        <id column="id" property="id"/>
        <result column="period" property="period"/>
        <result column="title" property="title"/>
        <result column="description" property="desc"/>
    </resultMap>

    <select id="selectAll" resultMap="TimelineMap">
        SELECT id, period, title, description FROM timeline_items ORDER BY id ASC
    </select>

    <select id="countById" resultType="int">
        SELECT COUNT(*) FROM timeline_items WHERE id = #{id}
    </select>

    <insert id="insert">
        INSERT INTO timeline_items (id, period, title, description)
        VALUES (#{id}, #{period}, #{title}, #{desc})
    </insert>
</mapper>
