# 复制为 application-prod.yml（该文件已 gitignore，勿提交真实密码）
# 服务器：cp application-prod.yml.example application-prod.yml 后修改，再 mvn package
# systemd 使用：--spring.profiles.active=prod

server:
  port: 8080
  servlet:
    context-path: /v1

spring:
  datasource:
    url: jdbc:mysql://127.0.0.1:3306/myblog?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
    username: blog_user
    password: 'CHANGE_ME'
  data:
    redis:
      host: 127.0.0.1
      port: 6379
      database: 5
  mail:
    username: ${QQ_SMTP_USER}
    password: ${QQ_SMTP_AUTH_CODE}

app:
  seed:
    enabled: false
  jwt:
    secret: 'CHANGE_ME_MIN_32_CHARS'
  dev:
    fixed-verification-code: ''
  upload:
    avatar-dir: /opt/blog/data/uploads/avatars
    content-dir: /opt/blog/data/uploads/content
  agent:
    ops-token: CHANGE_ME_SAME_AS_PYTHON
    base-url: http://127.0.0.1:8000
    chat-path: /ai/chat
    note-comment-path: /ai/internal/note-comment
    reply:
      note-enabled: true
  cors:
    allowed-origins: "https://你的域名"
  quiet-hours:
    enabled: true
    start: "23:00"
    end: "08:00"
    zone-id: Asia/Shanghai
    allow-user-ids:
      - 1
    allow-ips:
      - 127.0.0.1
      - ::1
    allow-auth-from-whitelist-ip: true
    bypass-path-patterns:
      - /agent/ops/**
