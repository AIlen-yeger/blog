# 复制为 .env 后填写（与 Spring Boot application-local.yml 对齐）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=你的MySQL密码
MYSQL_DB=myblog

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=5
REDIS_PASSWORD=

# DeepSeek / OpenAI 兼容接口
DP_MODEL=deepseek-chat
DP_AGENT_API_KEY=sk-你的DeepSeek密钥
DP_AGENT_API_URL=https://api.deepseek.com

# 开发时如需热重载再开启（聊天过程中勿改代码，否则会中断）
# AGENT_RELOAD=true

# Spring API（Agent 加歌调 /music/tracks）
# 必须带 http:// 或 https://；勿写成 127.0.0.1:8080/v1
BLOG_API_BASE=http://127.0.0.1:8080/v1

# 搜狗 MCP（Gradio 远程搜索；工具名是 predict，不是 sogou_search）
SOGOU_MCP_SSE_URL=https://phoenixdna-sogou-search.ms.show/gradio_api/mcp/sse
SOGOU_MCP_TOOL_NAME=predict

# 可选：关闭历史持久化（Redis/MySQL 不可用时）
# CHAT_HISTORY_ENABLED=false
# REDIS_ENABLED=false

# Agent 结构化日志（纯文件）
# AGENT_LOG_DIR=log/agent.log
# AGENT_LOG_TRACE_RETAIN_DAYS=14
# AGENT_LOG_SUMMARY_RETAIN_DAYS=90
# AGENT_LOG_ERROR_RETAIN_DAYS=180
# AGENT_LOG_INTENT_RETAIN_DAYS=14
# 进程内定时清理（Agent 启动后自动跑，默认开启）
# AGENT_LOG_PRUNE_ENABLED=true
# AGENT_LOG_PRUNE_ON_STARTUP=true
# AGENT_LOG_PRUNE_INTERVAL_HOURS=24
# AGENT_LOG_PRUNE_STARTUP_DELAY_SEC=60

# Bug Ops 内部 Agent（定时扫日志 + ERROR 告警，不对用户聊天暴露）
# BUG_AGENT_ENABLED=true
# BUG_AGENT_INTERVAL_HOURS=6
# BUG_AGENT_ALERT_ON_ERROR=true
# BUG_AGENT_MIN_SEVERITY=high
# AGENT_OPS_TOKEN=change-me-for-manual-scan
