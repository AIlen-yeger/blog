# 复制为 .env 后填写

# MySQL / Redis
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=0123
MYSQL_DB=myblog

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=5

# 闲聊 + 意图 judge + ReAct + 音乐子图（默认全部 DeepSeek，共用 Key）
DP_MODEL=deepseek-chat
DP_AGENT_API_KEY=sk-b263313134604e20b212e7307b8206a4
DP_CHAT_API_URL=https://api.deepseek.com
DP_CHAT_TEMPERATURE=0.7
DP_CHAT_HISTORY_LIMIT=10
# 可选单独指定 ReAct（不设则与上面相同）
# DP_REACT_MODEL=deepseek-chat
# DP_REACT_TEMPERATURE=0.0

# 千问意图识别（默认关闭；开启后才会读下面 DP_JUDGE_*，勿与 DeepSeek Key 混用）
# DP_JUDGE_ENABLED=false
# DP_JUDGE_MODEL=qwen-plus
# DP_JUDGE_API_KEY=sk-你的DashScope密钥
# DP_JUDGE_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 歌曲创作背景：搜狗 MCP（配置在 config/mcp_servers.json，外网不稳定可关）
SOGOU_MCP_ENABLED=true
SOGOU_MCP_SSE_URL=https://phoenixdna-sogou-search.ms.show/gradio_api/mcp/sse

# 与 Java developer.email 一致；仅该邮箱或 role=admin 可走 AiCoin 行情子图
# DEVELOPER_EMAIL=your@email.com
# QQ 私聊行情：主号 QQ（不设则用 NAPCAT_ALERT_QQ），须与博客 admin 或上面邮箱一致
# DEVELOPER_QQ=2762548283
# QQ 行情双阶段：轻量 ReAct 出 JSON → chat 润色（默认 true）；false 则单段 ReAct
# QQ_AICOIN_TWO_PHASE=true

# 实时查询虚拟币价格（仅管理员/开发者会话会进入 aicoin 子图）
AICOIN_MCP_ENABLED=true
DEVELOPER_EMAIL=2762548283@qq.com
QQ_AICOIN_TWO_PHASE=true
# MCP_SERVERS_CONFIG=config/mcp_servers.json

BLOG_API_BASE=http://127.0.0.1:8080/v1

# Bug Ops（内部排障，非用户聊天）
BUG_AGENT_ENABLED=true
BUG_AGENT_ALERT_ON_ERROR=true
BUG_AGENT_MIN_SEVERITY=high
# 手动巡检 / NapCat 测试需与下方一致
AGENT_OPS_TOKEN=agent-kohaku-jwt-secret-change-in-production-min-32-chars
# Java 与 Python 须相同；QQ 主号若在博客注册为 {QQ}@qq.com，桥接会自动签发 JWT

# Agent 日志目录（默认 log/agent；轮转历史在 archive/ 子目录）
# AGENT_LOG_DIR=log/agent

# NapCat QQ 告警（与 ECS 上 docker/napcat 同机时用 127.0.0.1:3000）
NAPCAT_NOTIFY_ENABLED=true
NAPCAT_HTTP_URL=http://127.0.0.1:3000
NAPCAT_ALERT_QQ=2762548283
# 若 NapCat 配置了 HTTP access_token，填相同值
# NAPCAT_ACCESS_TOKEN=
NAPCAT_MIN_SEVERITY=high
# 严重 ERROR 入队时先发一条 QQ，再跑 Bug Ops
NAPCAT_ALERT_ON_ERROR=true

# BTC 定投日报：每天北京时间 9:00 推送到 NAPCAT_ALERT_QQ（需 AICOIN_MCP_ENABLED）
# 开发者 QQ 私聊发「每日报告」「早报」「定投日报」等（须 DEVELOPER_QQ/admin）可立即触发同一条日报
BTC_DCA_DAILY_ENABLED=true
BTC_DCA_DAILY_TZ=Asia/Shanghai
BTC_DCA_DAILY_HOUR=9
BTC_DCA_DAILY_MINUTE=0
# 首次无状态文件时初始化（优先用 BTC 枚数 + 均价；也可用成本 USDT + 均价）
BTC_DCA_INITIAL_BTC_QTY=0.00288579
BTC_DCA_INITIAL_AVG_USDT=92212.5651
# BTC_DCA_INITIAL_COST_USDT=266.11

# QQ 私聊 Kohaku（qq-agent-mcp + Amadeus-QQ-MCP 仓库）
QQ_MCP_ENABLED=false
QQ_MCP_DIR=G:/Projects/Amadeus-QQ-MCP
QQ_MCP_BOT_QQ=3287192934
QQ_MCP_FRIENDS=2762548283
QQ_MCP_NAPCAT_HOST=127.0.0.1
QQ_MCP_NAPCAT_PORT=3000
QQ_MCP_WS_PORT=3001
# 与 NapCat HTTP/WS token 一致；不填则沿用 NAPCAT_ACCESS_TOKEN
# QQ_MCP_ACCESS_TOKEN=
QQ_MCP_POLL_INTERVAL_SEC=5
# 新设备/删状态文件后：首轮只建水位线，不对历史私聊自动回复（默认 true）
# QQ_MCP_BOOTSTRAP_ON_START=true
# 云上推荐（blog-agent 的 blog 用户 PATH 常无 uv）：
# QQ_MCP_PYTHON=/opt/Amadeus-QQ-MCP/.venv/bin/python
# 不填则自动用 $QQ_MCP_DIR/.venv/bin/python；勿写 QQ_MCP_UV_BIN=uv（非绝对路径会被忽略）
