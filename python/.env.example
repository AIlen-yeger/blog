# 复制为 .env 后填写

# MySQL / Redis
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=0123
MYSQL_DB=myblog

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=5

# 闲聊 + ReAct 工具（DeepSeek，默认共用）
DP_MODEL=deepseek-chat
DP_AGENT_API_KEY=sk-你的DeepSeek密钥
DP_CHAT_API_URL=https://api.deepseek.com
DP_CHAT_TEMPERATURE=0.7
DP_CHAT_HISTORY_LIMIT=10
# 可选单独指定 ReAct（不设则与上面相同）
# DP_REACT_MODEL=deepseek-chat
# DP_REACT_TEMPERATURE=0.0

# 意图识别 judge（千问 DashScope，兼容旧名 DP_EXECUTE_*）
DP_JUDGE_MODEL=qwen-plus
DP_JUDGE_API_KEY=sk-你的DashScope密钥
DP_JUDGE_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DP_JUDGE_TEMPERATURE=0.0

# ReAct 已是 DeepSeek 时一般不需要二次润色
MUSIC_FINAL_VIA_CHAT=false

BLOG_API_BASE=http://127.0.0.1:8080/v1

# Bug Ops（内部排障，非用户聊天）
BUG_AGENT_ENABLED=true
BUG_AGENT_ALERT_ON_ERROR=true
BUG_AGENT_MIN_SEVERITY=high
# 手动巡检 / NapCat 测试需与下方一致
AGENT_OPS_TOKEN=请设置一长串随机值

# NapCat QQ 告警（与 ECS 上 docker/napcat 同机时用 127.0.0.1:3000）
NAPCAT_NOTIFY_ENABLED=true
NAPCAT_HTTP_URL=http://127.0.0.1:3000
NAPCAT_ALERT_QQ=你的QQ号
# 若 NapCat 配置了 HTTP access_token，填相同值
# NAPCAT_ACCESS_TOKEN=
NAPCAT_MIN_SEVERITY=high
# 严重 ERROR 入队时先发一条 QQ，再跑 Bug Ops
NAPCAT_ALERT_ON_ERROR=true

# QQ 私聊 Kohaku（qq-agent-mcp + Amadeus-QQ-MCP 仓库）
QQ_MCP_ENABLED=false
QQ_MCP_DIR=G:/Projects/Amadeus-QQ-MCP
QQ_MCP_BOT_QQ=机器人QQ号
QQ_MCP_FRIENDS=主号QQ号
QQ_MCP_NAPCAT_HOST=127.0.0.1
QQ_MCP_NAPCAT_PORT=3000
QQ_MCP_WS_PORT=3001
QQ_MCP_POLL_INTERVAL_SEC=5
